# termbox.env — generated by termbox init
# Source this at the TOP of your shell rc file:
#   source "$HOME/Developer/termbox/config/shell/termbox.env"

export TERMBOX_HOME="${TERMBOX_HOME:-$HOME/Developer/termbox}"
export TERMBOX_DEV_FOLDER="${TERMBOX_DEV_FOLDER:-$HOME/Developer}"
export NOTE_FOLDER="${NOTE_FOLDER:-$HOME/Developer/notes}"
export TERMBOX_SHOW_SCREEN="${TERMBOX_SHOW_SCREEN:-true}"
export TERMBOX_CONFIG_DIR="${TERMBOX_CONFIG_DIR:-$HOME/.config/termbox}"
export TERMBOX_DATA_DIR="${TERMBOX_DATA_DIR:-$HOME/.local/share/termbox}"
export THEME_NAME="rosewood"

# Source the active theme file — sets all THEME_* vars for this session
if [[ -z "$TMUX" ]] && [[ "$SHLVL" -eq 1 ]]; then
    _tb_theme="$TERMBOX_DATA_DIR/themes/$THEME_NAME.theme"
    [ -f "$_tb_theme" ] && source "$_tb_theme"
    unset _tb_theme
fi

